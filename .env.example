# server
APP_NAME=codex-gateway-python
HOST=0.0.0.0
PORT=8080
ADMIN_TOKEN=change_me_admin_token
DATABASE_URL=sqlite+aiosqlite:///./data/gateway.db

# upstream (OpenClaw-like Codex backend)
UPSTREAM_BASE_URL=https://chatgpt.com/backend-api
# oauth_manual | env_token | codex_auth_file | auto
UPSTREAM_AUTH_MODE=oauth_manual
UPSTREAM_BEARER_TOKEN=
UPSTREAM_TIMEOUT_SECONDS=120
UPSTREAM_TRANSPORT=sse
UPSTREAM_OPENAI_BETA=responses=experimental

# manual OAuth / PKCE mode (OpenClaw-compatible Codex OAuth defaults)
OAUTH_AUTHORIZE_URL=https://auth.openai.com/oauth/authorize
OAUTH_TOKEN_URL=https://auth.openai.com/oauth/token
OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:1455/auth/callback
OAUTH_SCOPE=openid profile email offline_access
OAUTH_AUDIENCE=
OAUTH_ORIGINATOR=pi
OAUTH_CODEX_CLI_SIMPLIFIED_FLOW=true
OAUTH_ID_TOKEN_ADD_ORGANIZATIONS=true
OAUTH_SESSION_TTL_MINUTES=15

# optional older CLI bridge mode
CODEX_COMMAND=codex
CODEX_LOGIN_COMMAND=
CODEX_HOME=~/.codex
CODEX_AUTH_CREDENTIALS_STORE=file
CODEX_LOGIN_LOG_FILE=./data/codex-login.log

# optional default model allowlist, comma separated
DEFAULT_ALLOWED_MODELS=gpt-4.1-mini,gpt-4o-mini,codex-mini-latest
